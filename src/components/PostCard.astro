---
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  tags: string[];
  readingTime?: string;
}

const { title, description, slug, pubDate, tags, readingTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="card">
  <a href={`/blog/${slug}/`} style="color: inherit; text-decoration: none; opacity: 1;">
    <h3>{title}</h3>
    <p>{description}</p>
  </a>
  <div class="post-meta" style="margin-top: auto; font-size: 0.85rem;">
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    {readingTime && <span>· {readingTime}</span>}
  </div>
  {tags.length > 0 && (
    <div class="tag-bar" style="margin-top: 0.5rem;">
      {tags.map(tag => <Tag name={tag} />)}
    </div>
  )}
</article>
